{
  "version": 2,
  "builds": [
    {
      "src": "apps/website/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/api/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["packages/database/dist/**", "packages/database/prisma/**"]
      }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "apps/api/src/index.ts" },
    { "src": "/api/(.*)", "dest": "apps/api/src/index.ts" },
    { "handle": "filesystem" }
  ]
}
